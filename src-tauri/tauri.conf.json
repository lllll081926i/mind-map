{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mind Map Desktop",
  "version": "0.1.0",
  "identifier": "com.mindmap.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:desktop-web",
    "frontendDist": "../dist-desktop"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mind Map Desktop",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}
