{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["src/*"]
    },
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "types": ["node", "vite/client"]
  },
  "include": [
    "src/**/*.js",
    "src/**/*.vue",
    "src/**/*.d.ts",
    "tests/**/*.mjs",
    "vite.config.js",
    "vite.lib.config.js"
  ]
}
