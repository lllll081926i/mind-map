{
  "name": "mind-map-app",
  "version": "0.2.16",
  "private": true,
  "workspaces": [
    "simple-mind-map",
    "simple-mind-map-plugin-themes"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "scripts": {
    "dev": "npm run desktop:dev",
    "check": "npm run desktop:check",
    "lint": "eslint . --ext .js,.mjs,.cjs,.vue --cache --cache-location .eslintcache",
    "lint:fix": "npm run lint -- --fix",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "prepare": "husky",
    "test:update": "node --test tests/update-service-core.test.mjs",
    "test:utils": "node --test tests/json-utils.test.mjs",
    "test:desktop-runtime": "node --test tests/platform-runtime.test.mjs",
    "test:desktop-flow": "node --test tests/desktop-workspace-routing.test.mjs tests/workspace-actions.test.mjs tests/editor-topbar-entrypoints.test.mjs tests/export-page-layout.test.mjs tests/home-page-layout.test.mjs tests/workspace-settings-layout.test.mjs tests/workspace-session.test.mjs tests/workspace-resume-layout.test.mjs tests/design-panels-layout.test.mjs tests/ai-basic-experience.test.mjs tests/ai-store-session.test.mjs tests/flowchart-document.test.mjs tests/flowchart-editor-layout.test.mjs tests/flowchart-ai-generation.test.mjs tests/mindmap-editor-ux.test.mjs",
    "test:behavior": "node --test tests/ai-proxy-server.test.mjs tests/p0-p1-hardening.test.mjs tests/p2-governance.test.mjs tests/file-association-config.test.mjs tests/review-remediation.test.mjs tests/desktop-startup-performance.test.mjs",
    "test:root": "node --test tests/*.test.mjs",
    "test:all": "npm run test:root",
    "test:e2e": "playwright test",
    "frontend:dev": "vite",
    "build": "npm run frontend:build && npm run desktop:check",
    "frontend:build": "vite build --mode desktop",
    "build:library": "node ./scripts/updateVersion.js && vite build --config ./vite.lib.config.js && node ./scripts/build-library-min.js",
    "buildLibrary": "npm run build:library",
    "createNodeImageList": "node ./scripts/createNodeImageList.js",
    "tauri": "tauri",
    "ai:serve": "node ./scripts/ai.js",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build --bundles nsis --config src-tauri/tauri.release.conf.json",
    "desktop:build:windows": "tauri build --bundles nsis --config src-tauri/tauri.release.conf.json",
    "desktop:build:linux": "tauri build --bundles deb,appimage --config src-tauri/tauri.release.conf.json",
    "desktop:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "format": "prettier --write \"src/**/*.{js,ts,vue,css,less,html,json}\"",
    "frontend:preview": "vite preview"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@toast-ui/editor": "^3.2.2",
    "axios": "^1.15.0",
    "buffer": "^6.0.3",
    "codemirror": "^5.65.21",
    "dompurify": "^3.3.3",
    "element-plus": "^2.13.6",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.44",
    "pinia": "^3.0.4",
    "simple-mind-map": "workspace:*",
    "simple-mind-map-plugin-themes": "workspace:*",
    "viewerjs": "^1.11.7",
    "vue": "^3.5.32",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.55.0",
    "@tauri-apps/cli": "^2.10.1",
    "@types/express": "^5.0.3",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "esbuild": "^0.27.7",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "events": "^3.3.0",
    "express": "^5.2.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "less": "^4.6.4",
    "markdown-it": "^14.1.1",
    "prettier": "^3.8.1",
    "stream-browserify": "^3.0.0",
    "typescript": "^6.0.2",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.8",
    "vue-eslint-parser": "^10.4.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "overrides": {
    "dompurify": "^3.3.3",
    "follow-redirects": "1.16.0",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "quill": "2.0.2"
  }
}
