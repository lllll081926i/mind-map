{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mind Map Desktop",
  "version": "0.2.3",
  "identifier": "com.mindmap.desktop",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run frontend:build",
    "frontendDist": "../dist-desktop"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mind Map Desktop",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' http://localhost:* ws://localhost:* https://github.com https://api.github.com https://objects.githubusercontent.com https://*.githubusercontent.com; frame-src 'none'; object-src 'none'; media-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "useLocalToolsDir": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "shortDescription": "Desktop mind map editor",
    "longDescription": "Mind map desktop application for Windows, macOS, and Linux.",
    "windows": {
      "digestAlgorithm": "sha256"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/lllll081926i/mind-map/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJFNUZFNDUwNkY0NzFDNTgKUldSWUhFZHZVT1JmTHF2RU9XNnNXYzZuaFJIZXBvMXZCT2dyTGJ3TFFMOHhzM3Z5OXBSRXEvTXYK"
    }
  }
}
