{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["src/*"]
    },
    "allowJs": true,
    "checkJs": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "types": ["node", "vite/client"]
  },
  "include": [
    "src/**/*.d.ts",
    "src/utils/json.js",
    "src/utils/aiProviders.mjs",
    "scripts/ai.js",
    "scripts/test-ai-provider.mjs",
    "tests/json-utils.test.mjs",
    "tests/ai-proxy-server.test.mjs",
    "tests/p0-p1-hardening.test.mjs"
  ]
}
