{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MindMap",
  "version": "0.2.16",
  "identifier": "com.mindmap.desktop",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run frontend:build",
    "frontendDist": "../dist-desktop"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MindMap",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https: https://asset.localhost; font-src 'self' data:; connect-src 'self' http://localhost:5173 ws://localhost:5173 http://127.0.0.1:5173 ws://127.0.0.1:5173 http://localhost:3456 http://127.0.0.1:3456 https: wss:; frame-src 'none'; object-src 'none'; media-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "useLocalToolsDir": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "file-association/icons/smm-document.ico": "file-association/icons/smm-document.ico"
    },
    "fileAssociations": [
      {
        "ext": [
          "smm"
        ],
        "name": "MindMap Document",
        "description": "MindMap 思维导图文档",
        "role": "Editor",
        "rank": "Owner",
        "mimeType": "application/x-mindmap-smm",
        "contentTypes": [
          "com.mindmap.document.smm"
        ],
        "exportedType": {
          "identifier": "com.mindmap.document.smm",
          "conformsTo": [
            "public.data"
          ]
        }
      }
    ],
    "shortDescription": "MindMap editor",
    "longDescription": "MindMap application for Windows and Linux.",
    "windows": {
      "digestAlgorithm": "sha256",
      "nsis": {
        "installerHooks": "file-association/windows/smm-file-association.nsh"
      }
    },
    "linux": {
      "appimage": {
        "files": {
          "usr/share/applications/mindmap-smm.desktop": "file-association/linux/mindmap-smm.desktop",
          "usr/share/mime/packages/application-x-mindmap-smm.xml": "file-association/linux/application-x-mindmap-smm.xml",
          "usr/share/icons/hicolor/scalable/mimetypes/application-x-mindmap-smm.svg": "file-association/icons/application-x-mindmap-smm.svg",
          "usr/share/icons/hicolor/128x128/mimetypes/application-x-mindmap-smm.png": "file-association/icons/application-x-mindmap-smm.png"
        }
      },
      "deb": {
        "depends": [],
        "files": {
          "usr/share/applications/mindmap-smm.desktop": "file-association/linux/mindmap-smm.desktop",
          "usr/share/mime/packages/application-x-mindmap-smm.xml": "file-association/linux/application-x-mindmap-smm.xml",
          "usr/share/icons/hicolor/scalable/mimetypes/application-x-mindmap-smm.svg": "file-association/icons/application-x-mindmap-smm.svg",
          "usr/share/icons/hicolor/128x128/mimetypes/application-x-mindmap-smm.png": "file-association/icons/application-x-mindmap-smm.png"
        },
        "postInstallScript": "file-association/linux/postinstall.sh",
        "postRemoveScript": "file-association/linux/postremove.sh"
      }
    }
  }
}
